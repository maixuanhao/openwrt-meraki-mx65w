# ==========================================================
# 1. ĐỊNH DANH PHẦN CỨNG CISCO MERAKI MX65W (CHIP BROADCOM)
# ==========================================================
CONFIG_TARGET_bcm53xx=y
CONFIG_TARGET_bcm53xx_generic=y
CONFIG_TARGET_bcm53xx_generic_DEVICE_meraki_mx65w=y

# ==========================================================
# 2. DRIVER ĐẶC THÙ CHO CỔNG MẠNG & SWITCH CỦA MERAKI
# ==========================================================
CONFIG_PACKAGE_kmod-switch-qca8337=y
CONFIG_PACKAGE_kmod-swconfig=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_bridge-utils=y
CONFIG_PACKAGE_kmod-i2c-bcmiproc=y
CONFIG_PACKAGE_kmod-i2c-core=y

# ==========================================================
# 3. GIAO DIỆN HỆ THỐNG & ĐỔI TIẾNG VIỆT FULL TÍNH NĂNG
# ==========================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_LUCI_LANG_vi=y
CONFIG_PACKAGE_luci-i18n-base-vi=y
CONFIG_PACKAGE_luci-i18n-base-en=y

# Giao diện Modern Argon Theme
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ==========================================================
# 4. TIỆN ÍCH DÒNG LỆNH & HỆ THỐNG (SSH/SERIAL)
# ==========================================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_lsblk=y

# ==========================================================
# 5. KÍCH HOẠT HỆ THỐNG DOCKER (BẬT SẴN NHÂN KERNEL CGROUP)
# ==========================================================
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-vi=y
CONFIG_DOCKER_CGROUP_OPTIONS=y
CONFIG_DOCKER_NET_MACVLAN=y
CONFIG_DOCKER_STO_EXT4=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_NET_PRIO=y
CONFIG_KERNEL_NET_CLS_CGROUP=y

# ==========================================================
# 6. MẠNG ẢO VPN & CÔNG CỤ XUYÊN TƯỜNG BẢO MẬT CAO
# ==========================================================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_haproxy=y
CONFIG_PACKAGE_shadowsocks-rust-sslocal=y
CONFIG_PACKAGE_shadowsocks-rust-ssserver=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_tcping=y

# Tương thích tường lửa nftables mới bắt buộc cho OpenVPN/Clash
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

# ==========================================================
# 7. CHẶN QUẢNG CÁO & PHÂN GIẢI TÊN MIỀN
# ==========================================================
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-vi=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-vi=y

# ==========================================================
# 8. BỘ NHỚ LƯU TRỮ USB, FILE SERVER (SAMBA4 / KSMBD / NAS)
# ==========================================================
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_PACKAGE_kmod-fs-btrfs=y

# Giao thức chia sẻ File (Samba4 & ksmbd Kernel mới)
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-vi=y
CONFIG_PACKAGE_ksmbd-server=y
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_luci-i18n-ksmbd-vi=y
CONFIG_SAMBA4_SERVER_AVAHI=y
CONFIG_SAMBA4_SERVER_NETBIOS=y
CONFIG_SAMBA4_SERVER_WSDD2=y

# ==========================================================
# 9. ĐỒNG BỘ DỮ LIỆU TẢI FILE & TRUYỀN THÔNG (MEDIA SERVER)
# ==========================================================
CONFIG_PACKAGE_aria2=y
CONFIG_PACKAGE_ariang=y
CONFIG_PACKAGE_luci-app-aria2=y
CONFIG_PACKAGE_luci-i18n-aria2-vi=y
CONFIG_ARIA2_BITTORRENT=y
CONFIG_ARIA2_OPENSSL=y
CONFIG_ARIA2_WEBSOCKET=y

CONFIG_PACKAGE_minidlna=y
CONFIG_PACKAGE_luci-app-minidlna=y
CONFIG_PACKAGE_luci-i18n-minidlna-vi=y

# ==========================================================
# 10. QUẢN LÝ ĐIỆN NĂNG, XUNG NHỊP CPU & THEO DÕI HỆ THỐNG
# ==========================================================
CONFIG_PACKAGE_cpufreq=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_hd-idle=y
CONFIG_PACKAGE_luci-app-hd-idle-vi=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-irqbalance=y
CONFIG_PACKAGE_luci-i18n-irqbalance-vi=y
CONFIG_PACKAGE_netdata=y
CONFIG_PACKAGE_luci-app-netdata=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-vi=y
